function calculateExpression(text){


    try{


        const expression =
            text
            .replace(
                /計算|して|ください|は|？|\?/g,
                ""
            )
            .replace(
                /足す/g,
                "+"
            )
            .replace(
                /引く/g,
                "-"
            )
            .replace(
                /掛ける|かける/g,
                "*"
            )
            .replace(
                /割る/g,
                "/"
            );


        if(
            /^[0-9+\-*/().\s]+$/
            .test(expression)
        ){


            return (

                "計算結果は\n\n" +

                Function(
                    "return "
                    +
                    expression
                )()

            );

        }


    }catch(e){


        return null;

    }


    return null;

}







