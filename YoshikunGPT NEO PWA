function escapeHTML(text){

    if(text==null){

        return "";

    }

    return String(text)

    .replace(/&/g,"&amp;")

    .replace(/</g,"&lt;")

    .replace(/>/g,"&gt;")

    .replace(/"/g,"&quot;")

    .replace(/'/g,"&#039;");

}

/*==============================
  Markdown
==============================*/

function markdown(text){

    let html = escapeHTML(text);

    html = html.replace(

        /\*\*(.*?)\*\*/g,

        "<strong>$1</strong>"

    );

    html = html.replace(

        /\*(.*?)\*/g,

        "<em>$1</em>"

    );

    html = html.replace(

        /`([^`]+)`/g,

        "<code>$1</code>"

    );

    html = html.replace(

        /\n/g,

        "<br>"

    );

    return html;

}

