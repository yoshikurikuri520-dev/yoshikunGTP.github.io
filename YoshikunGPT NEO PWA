function exportBackup(){



    if(
        typeof YoshikunStorage
        ===
        "undefined"
    ){

        return null;

    }



    const data =

        YoshikunStorage
        .backup();



    const blob =

        new Blob(

            [
                data
            ],

            {
                type:
                "application/json"
            }

        );



    const url =

        URL
        .createObjectURL(
            blob
        );




    const a =

        document
        .createElement(
            "a"
        );



    a.href = url;



    a.download =

        "yoshikunGPT_backup.json";



    a.click();



    URL
    .revokeObjectURL(
        url
    );


}









