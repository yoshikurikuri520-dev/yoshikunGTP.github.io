/*
==================================
 キーワード検索エンジン
==================================
*/


function searchKnowledge(input){


    const text =
        input.toLowerCase();



    for(
        const category
        in YOSHIKUN_KNOWLEDGE
    ){


        const data =
            YOSHIKUN_KNOWLEDGE[category];


        if(!data.patterns)
            continue;



        for(
            const keyword
            of data.patterns
        ){


            if(
                text.includes(
                    keyword.toLowerCase()
                )
            ){


                const answers =
                    data.answers;


                return answers[
                    Math.floor(
                        Math.random()
                        *
                        answers.length
                    )
                ];

            }

        }

    }


    return null;

}

