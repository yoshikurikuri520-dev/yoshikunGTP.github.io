/*
==================================
 Markdown簡易変換
==================================
*/


function renderMarkdown(text){


    if(
        !text
    ){

        return "";

    }



    let html =
        text;



    // 太字

    html =
        html.replace(

            /\*\*(.*?)\*\*/g,

            "<strong>$1</strong>"

        );



    // 改行

    html =
        html.replace(

            /\n/g,

            "<br>"

        );



    // コード

    html =
        html.replace(

            /`(.*?)`/g,

            "<code>$1</code>"

        );



    return html;


}








