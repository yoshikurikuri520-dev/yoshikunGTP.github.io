/*==================================================
  Similarity
==================================================*/

function similarity(a,b){

    a=normalizeInput(a);

    b=normalizeInput(b);

    if(a===b){

        return 1;

    }

    const wa=splitKeywords(a);

    const wb=splitKeywords(b);

    let score=0;

    wa.forEach(word=>{

        if(wb.includes(word)){

            score++;

        }

    });

    return score/

    Math.max(

        wa.length,

        wb.length,

        1

    );

}

