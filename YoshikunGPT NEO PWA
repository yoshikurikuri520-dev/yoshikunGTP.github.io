/*
==================================
 質問意図解析
==================================
*/


function analyzeIntent(text){


    const intents = {


        question:false,

        request:false,

        problem:false,

        greeting:false,

        emotion:false

    };



    if(
        text.includes("?") ||
        text.includes("？") ||
        text.includes("教えて")
    ){

        intents.question = true;

    }



    for(
        const key in YOSHIKUN_SYNONYMS
    ){


        for(
            const word of YOSHIKUN_SYNONYMS[key]
        ){


            if(
                text.includes(word)
            ){


                if(key==="hello")
                    intents.greeting=true;


                if(key==="problem")
                    intents.problem=true;


                if(key==="create")
                    intents.request=true;


                if(key==="explain")
                    intents.question=true;

            }

        }

    }



    return intents;

}








